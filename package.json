{
  "name": "padlokbackend",
  "version": "1.0.0",
  "description": "Robust escrow backend with Express, Postgres, and secure auth",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "migrate": "ts-node src/database/runMigrations.ts",
    "migrate:down": "ts-node src/database/rollbackMigrations.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "escrow",
    "backend",
    "express",
    "postgres"
  ],
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "paystack-sdk": "^3.6.1",
    "pg": "^8.18.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
